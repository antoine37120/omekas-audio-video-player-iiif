<?php
$this->htmlElement('body')->appendAttribute('class', 'audio-player annotation index');
$escape = $this->plugin('escapeHtml');
?>

<h1><?php echo $escape('Audio Player Annotations'); ?></h1>

<?php echo $this->messages(); ?>

<div class="search-form-container">
    <form action="" method="get">
        <div class="search-entry">
            <label for="q"><?php echo $escape('Search (Title/Content)'); ?></label>
            <input type="text" name="q" id="q" value="<?php echo $escape($params['q'] ?? ''); ?>">
        </div>
        <div class="search-entry">
            <label for="resource_id"><?php echo $escape('Resource ID'); ?></label>
            <input type="number" name="resource_id" id="resource_id" value="<?php echo $escape($params['resource_id'] ?? ''); ?>">
        </div>
        <div class="search-entry">
            <label for="author_id"><?php echo $escape('Author ID'); ?></label>
            <input type="number" name="author_id" id="author_id" value="<?php echo $escape($params['author_id'] ?? ''); ?>">
        </div>
        <div class="search-entry">
            <label for="per_page"><?php echo $escape('Per page'); ?></label>
            <select name="per_page" id="per_page">
                <?php foreach ([5, 10, 25, 50, 100] as $count): ?>
                <option value="<?php echo $count; ?>" <?php echo $perPage == $count ? 'selected' : ''; ?>><?php echo $count; ?></option>
                <?php endforeach; ?>
            </select>
        </div>
        <button type="submit" class="button"><?php echo $escape('Filter'); ?></button>
        <?php if (!empty($params)): ?>
            <a href="<?php echo $escape($this->url('admin/audio-player')); ?>" class="button reset"><?php echo $escape('Reset'); ?></a>
        <?php endif; ?>
    </form>
</div>

<div class="pagination-top">
    <?php echo $this->pagination(); ?>
</div>

<table class="tablesaw tablesaw-stack">
    <thead>
        <tr>
            <th><?php echo $escape('Title'); ?></th>
            <th><?php echo $escape('Description'); ?></th>
            <th><?php echo $escape('Time'); ?></th>
            <th><?php echo $escape('Author'); ?></th>
            <th><?php echo $escape('Resource ID'); ?></th>
            <th><?php echo $escape('Created'); ?></th>
            <th><?php echo $escape('Action'); ?></th>
        </tr>
    </thead>
    <tbody>
        <?php foreach ($annotations as $annotation): ?>
        <tr>
            <td><?php echo $escape($annotation['title']); ?></td>
            <td><?php echo $escape($annotation['description']); ?></td>
            <td><?php echo $escape(gmdate("H:i:s", (int)$annotation['time']) . ' - ' . gmdate("H:i:s", (int)$annotation['time_end'])); ?></td>
            <td>
                <?php echo $escape($annotation['author_name'] ?? 'Unknown'); ?>
                <?php if (!empty($annotation['author_id'])): ?>
                    <small>(ID: <?php echo $escape($annotation['author_id']); ?>)</small>
                <?php endif; ?>
            </td>
            <td>
                <?php if (!empty($annotation['resource_id'])): ?>
                    <a href="<?php echo $escape($this->url('admin/default', ['controller' => 'media', 'action' => 'show', 'id' => $annotation['resource_id']])); ?>">
                        <?php echo $escape($annotation['resource_id']); ?>
                    </a>
                <?php endif; ?>
            </td>
            <td><?php echo $escape($annotation['date']); ?></td>
            <td>
                <a href="<?php echo $escape($this->url('admin/audio-player', ['action' => 'delete', 'id' => $annotation['id']])); ?>" 
                   class="delete-confirm button button-delete"
                   onclick="return confirm('<?php echo $escape('Are you sure you want to delete this annotation?'); ?>');">
                    <?php echo $escape('Delete'); ?>
                </a>
            </td>
        </tr>
        <?php endforeach; ?>
    </tbody>
</table>

<div class="pagination-bottom">
    <?php echo $this->pagination(); ?>
</div>

