<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\MediaRepresentation $media
 */
$media = $this->media;
?>
<!DOCTYPE html>
<html lang="<?php echo $this->lang(); ?>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audio Player Embed</title>
    <link rel="stylesheet" href="<?php echo $this->assetUrl('vendor/audio-video-player-iiif/dist/player-iiif-vis.css', 'AudioPlayer'); ?>">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            overflow: hidden;
            font-family: "Open Sans", sans-serif;
        }

        annotation-player-iiif .player-container {
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            font-size: initial;
            line-height: normal;
        }

    </style>
</head>
<body>
    <?php if ($media): ?>
        <?php 
        $siteSlug = $this->params()->fromRoute('site-slug');
        $apiBaseUrl = $this->url('site/audio-player/annotation', ['site-slug' => $siteSlug], ['force_canonical' => true]);
        $iiifUrl = $this->url('site/audio-player/annotation-iiif', ['site-slug' => $siteSlug, 'id' => $media->id()], ['force_canonical' => true]);

        $mediaUrl = $this->mediaUrl;
        $waveformUrl = $this->waveformUrl;
        $subtitlesJson = $this->subtitlesJson ?? '[]';
        
        $waveformStrokeColor = $this->setting('audioplayer_waveform_stroke_color', 'rgba(0, 0, 0, 0.18)');
        $waveformStrokeWidth = $this->setting('audioplayer_waveform_stroke_width', '1');
        $annotationMinTimeToDisplay = $this->setting('audioplayer_annotation_min_time_to_display', '15');
        $annotationPropertiesToDisplay = $this->setting('audioplayer_annotation_properties_to_display', 'time,text,creator.id');
        $colors = $this->setting('audioplayer_colors', '');
        $playbackRates = $this->setting('audioplayer_playback_rates', '[0.5, 1, 1.5, 2, 4]');
        $canAddAnnotation = $this->identity() ? 'true' : 'false';
        // URL de la page embed (cette page elle-même)
        $embedUrl = $this->url('site/audio-player/embed', ['site-slug' => $siteSlug, 'id' => $media->item()->id()], ['force_canonical' => true]);
        $mediaUrl = $this->mediaUrl ?? ($media ? $media->originalUrl() : '');
        ?>
        <annotation-player-iiif
            api-base-url="<?php echo $this->escapeHtml($apiBaseUrl); ?>"
            resource-id="<?php echo $this->escapeHtml($media->id()); ?>"
            iiif-annotation-list-url="<?php echo $this->escapeHtml($iiifUrl); ?>"
            media-url="<?php echo $this->escapeHtml($mediaUrl); ?>"
            media-type="<?php echo $this->playerService->getMediaType($media); ?>"
            wave-form-url="<?php echo $this->escapeHtml($waveformUrl); ?>"
            waveform-stroke-color="<?php echo $this->escapeHtml($waveformStrokeColor); ?>"
            waveform-stroke-width="<?php echo $this->escapeHtml($waveformStrokeWidth); ?>"
            annotation-min-time-to-display="<?php echo $this->escapeHtml($annotationMinTimeToDisplay); ?>"
            annotation-properties-to-display="<?php echo $this->escapeHtml($annotationPropertiesToDisplay); ?>"
            force-embedded-mode="true"
            can-add-annotation="<?php echo $canAddAnnotation; ?>"
            can-edit-all-annotation="false"
            iiif-permissions-path="omeka:permissions"
            permissions-map="add:create,edit:edit,delete:delete"
            share-iframe-url="<?php echo $this->escapeHtml($embedUrl); ?>"
            playback-rates="<?php echo $this->escapeHtml($playbackRates); ?>"
            <?php echo $colors ? 'colors=\'' . $this->escapeHtml($colors) . '\'' : ''; ?>
            subtitle-files-url='<?php echo $this->escapeHtml($subtitlesJson); ?>'
        ></annotation-player-iiif>
        <script type="module" src="<?php echo $this->assetUrl('vendor/audio-video-player-iiif/dist/player-iiif-vis.js', 'AudioPlayer'); ?>"></script>
    <?php elseif ($this->isDebug && !empty($this->reasons)): ?>
        <div style="padding: 20px; color: #856404; background-color: #fff3cd; border: 1px solid #ffeeba; border-radius: 4px;">
            <p><strong>AudioPlayer Debug (Embed):</strong></p>
            <ul>
                <?php foreach ($this->reasons as $reason): ?>
                    <li><?php echo $this->escapeHtml($this->translate($reason)); ?></li>
                <?php endforeach; ?>
            </ul>
        </div>
    <?php else: ?>
        <p>Resource not found or incompatible.</p>
    <?php endif; ?>
</body>
</html>
