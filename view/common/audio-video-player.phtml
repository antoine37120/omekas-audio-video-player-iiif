// Génération de l'URL pour l'embed (utilisée pour l'iframe)
$embedUrl = $this->url(
    'site/audio-player/embed',
    ['site-slug' => $siteSlug, 'id' => $media->item()->id()],
    ['force_canonical' => true]
);
