    $apiBaseUrl = $this->url('site/audio-player/annotation', ['site-slug' => $siteSlug], ['force_canonical' => true]);
    $resourceId = $media ? $media->id() : '';
    $mediaId = $media ? $media->id() : '';
    $mediaUrl = $mediaUrl ?? ($media ? $media->originalUrl() : '');
