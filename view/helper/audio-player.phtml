// Fonction helper pour obtenir le type MIME
function getMimeType($url) {
    $extension = strtolower(pathinfo($url, PATHINFO_EXTENSION));
    $mimeTypes = [
        'mp3' => 'audio/mpeg',
        'wav' => 'audio/wav',
        'ogg' => 'audio/ogg',
        'flac' => 'audio/flac',
        'm4a' => 'audio/mp4',
        'aac' => 'audio/aac',
        'wma' => 'audio/x-ms-wma'
    ];

    return isset($mimeTypes[$extension]) ? $mimeTypes[$extension] : 'audio/mpeg';
}
