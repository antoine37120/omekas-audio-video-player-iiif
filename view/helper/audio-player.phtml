    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Gérer les erreurs de chargement audio
            const audioElements = document.querySelectorAll('.audio-player-container audio');
            audioElements.forEach(function(audio) {
                audio.addEventListener('error', function() {
                    const container = this.closest('.audio-player-item');
                    const errorMsg = document.createElement('div');
                    errorMsg.className = 'audio-error';
                    errorMsg.style.color = '#d32f2f';
                    errorMsg.style.fontSize = '0.9em';
                    errorMsg.textContent = '<?php echo $this->translate('Erreur lors du chargement du fichier audio.'); ?>';
                    container.appendChild(errorMsg);
